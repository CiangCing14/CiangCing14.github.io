				<li id="archives-4" class="widget-container widget_archive"><h3 class="widget-title">Arkistot</h3>
			<ul>
					<li><a href='https://punalippu.noblogs.org/post/2023/03/'>March 2023</a></li>
	<li><a href='https://punalippu.noblogs.org/post/2023/02/'>February 2023</a></li>
	<li><a href='https://punalippu.noblogs.org/post/2023/01/'>January 2023</a></li>
	<li><a href='https://punalippu.noblogs.org/post/2022/12/'>December 2022</a></li>
	<li><a href='https://punalippu.noblogs.org/post/2022/11/'>November 2022</a></li>
	<li><a href='https://punalippu.noblogs.org/post/2022/10/'>October 2022</a></li>
	<li><a href='https://punalippu.noblogs.org/post/2022/09/'>September 2022</a></li>
