<figure class="wp-block-image size-large"><img alt="" class="wp-image-11844 below-entry-meta" data-attachment-id="11844" data-comments-opened="1" data-id="11844" data-image-caption="" data-image-description="" data-image-meta="{&quot;aperture&quot;:&quot;0&quot;,&quot;credit&quot;:&quot;ZARZIS WEB&quot;,&quot;camera&quot;:&quot;&quot;,&quot;caption&quot;:&quot;&quot;,&quot;created_timestamp&quot;:&quot;0&quot;,&quot;copyright&quot;:&quot;&quot;,&quot;focal_length&quot;:&quot;0&quot;,&quot;iso&quot;:&quot;0&quot;,&quot;shutter_speed&quot;:&quot;0&quot;,&quot;title&quot;:&quot;&quot;,&quot;orientation&quot;:&quot;0&quot;}" data-image-title="323162622_726029158946732_8454103236218520797_n" data-large-file="https://proletaricomunisti.files.wordpress.com/2023/01/323162622_726029158946732_8454103236218520797_n.jpg?w=840" data-medium-file="https://proletaricomunisti.files.wordpress.com/2023/01/323162622_726029158946732_8454103236218520797_n.jpg?w=300" data-orig-file="https://proletaricomunisti.files.wordpress.com/2023/01/323162622_726029158946732_8454103236218520797_n.jpg" data-orig-size="2048,1152" data-permalink="https://proletaricomunisti.wordpress.com/2023/01/11/il-governo-razzista-meloni-rinnova-la-crociata-anti-migranti-e-afferma-gli-interessi-italiani-nel-mediterraneo-ed-in-tunisia-in-particolare/323162622_726029158946732_8454103236218520797_n/" height="225" src="https://proletaricomunisti.files.wordpress.com/2023/01/323162622_726029158946732_8454103236218520797_n.jpg?w=1024" width="400" /></figure>



