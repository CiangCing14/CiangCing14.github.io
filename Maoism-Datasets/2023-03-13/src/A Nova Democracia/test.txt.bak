                    <figure class="fox-figure post-thumbnail post-thumbnail-standard hover-none thumbnail-acute"  itemscope itemtype="https://schema.org/ImageObject"><span class="image-element thumbnail-inner"><img width="1000" height="714" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201000%20714'%3E%3C/svg%3E" class="attachment-full size-full" alt="" decoding="async" data-lazy-srcset="https://anovademocracia.com.br/storage/2023/03/EditorialSemanal070322-1.jpg 1000w, https://anovademocracia.com.br/storage/2023/03/EditorialSemanal070322-1-300x214.jpg 300w, https://anovademocracia.com.br/storage/2023/03/EditorialSemanal070322-1-768x548.jpg 768w, https://anovademocracia.com.br/storage/2023/03/EditorialSemanal070322-1-480x343.jpg 480w" data-lazy-sizes="(max-width: 1000px) 100vw, 1000px" data-lazy-src="https://anovademocracia.com.br/storage/2023/03/EditorialSemanal070322-1.jpg" /><noscript><img width="1000" height="714" src="https://anovademocracia.com.br/storage/2023/03/EditorialSemanal070322-1.jpg" class="attachment-full size-full" alt="" decoding="async" srcset="https://anovademocracia.com.br/storage/2023/03/EditorialSemanal070322-1.jpg 1000w, https://anovademocracia.com.br/storage/2023/03/EditorialSemanal070322-1-300x214.jpg 300w, https://anovademocracia.com.br/storage/2023/03/EditorialSemanal070322-1-768x548.jpg 768w, https://anovademocracia.com.br/storage/2023/03/EditorialSemanal070322-1-480x343.jpg 480w" sizes="(max-width: 1000px) 100vw, 1000px" /></noscript></span></figure>                    
